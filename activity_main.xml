<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D1117">

    <!-- Icon -->
    <TextView
        android:id="@+id/iconView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍"
        android:textSize="80sp"
        android:layout_marginBottom="24dp"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Location App"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send your location to Telegram"
        android:textSize="15sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="40dp"/>

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:padding="24dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 This app needs location permission to send your current location to Telegram.\n\nPlease press Allow to continue."
            android:textSize="15sp"
            android:textColor="#C9D1D9"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <!-- Allow Button -->
    <Button
        android:id="@+id/allowBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="✅  ALLOW LOCATION"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#238636"
        android:layout_marginBottom="12dp"/>

    <!-- Deny Button -->
    <Button
        android:id="@+id/denyBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="❌  DENY"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#21262D"/>

</LinearLayout>
